# ──────────────────────────────────────────────────────────────
# Supabase — required for all environments
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>        # server/worker ONLY — never in browser

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Token encryption (min 32 chars)
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY=<generate-a-random-32-plus-char-hex-string>

# ──────────────────────────────────────────────────────────────
# Redis / BullMQ — Railway (Phase 4)
# Leave blank to disable background jobs
# ──────────────────────────────────────────────────────────────
REDIS_URL=

# ──────────────────────────────────────────────────────────────
# Google OAuth — Phase 6
# Leave blank to disable Google Calendar / Meet integration
# ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ──────────────────────────────────────────────────────────────
# Slack — Phase 5
# Leave blank to disable Slack integration
# ──────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=                    # optional: socket mode

# ──────────────────────────────────────────────────────────────
# Stripe — Phase 3
# Leave blank to disable payments
# ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────
# Email — Phase 4
# Leave blank to disable transactional email nudges
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
